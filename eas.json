{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.x",
      "env": {
        "EAS_NO_NPM_CI": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.x",
      "env": {
        "EAS_NO_NPM_CI": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.x",
      "env": {
        "EAS_NO_NPM_CI": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
